# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=satuser
DB_PASSWORD=satpass123
DB_DATABASE=satpayload
DB_SYNC=true
DB_LOGGING=false

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
COMMAND_THROTTLE_LIMIT=10

# Simulator
TELEMETRY_INTERVAL_MS=2000
